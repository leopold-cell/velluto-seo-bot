.env
token_usage.json
topics_used.json
cron.log
__pycache__/
*.pyc
venv/
.venv/

# Phase 1+ research artifacts — large, ephemeral, not source-of-truth.
data/raw/
data/snapshots/
data/processed/*
!data/raw/.gitkeep
!data/snapshots/.gitkeep
!data/processed/.gitkeep

# Phase 3+ daily output — regenerated every cron run on the VPS.
output/*
!output/.gitkeep
!output/localization_briefs/
# 28-day blog review reports are an audit trail — keep them versioned.
!output/blog_review/
!output/blog_review/**

# Local-only logs
manual_test.log

# Secrets & editor backups (never commit — see .env.save leak 2026-06-30)
.env
.env.*
*.save
*.bak
*~
# Google service-account key for Drive uploads (drive_upload.py) — secret, never commit.
gdrive_sa.json
*service_account*.json
credentials*.json
# Local reel renders
output/reels/
